{
  "description": "Declaración de hooks del plugin pm. El usuario los activa configurando .pm/config.json (sección features y validation). Esta declaración se inyecta en el .claude/settings.json del usuario por el wizard /pm:init (futuro) o manualmente copiando este bloque.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/check-readme-edit.js\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "report-writer",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-report.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/check-inbox-empty.js\""
          }
        ]
      }
    ]
  }
}
